{
  "lwc": {
    "modules": [
      { "dir": "$rootDir/src/modules" },
      { "npm": "lightning-base-components" }
    ]
  },
  "routes": [
    {
      "id": "home",
      "path": "/",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    },
    {
      "id": "customers",
      "path": "/customers",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    },
    {
      "id": "contact",
      "path": "/contact",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    },
    {
      "id": "accordion",
      "path": "/accordion",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    },
    {
      "id": "usersettings",
      "path": "/usersettings",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    },
    {
      "id": "gallery",
      "path": "/gallery",
      "rootComponent": "main/app",
      "layoutTemplate": "$layoutsDir/index.njk",
      "bootstrap": {
        "syntheticShadow": true
      }
    }
  ],
  "assets": [
    {
      "alias": "favicon",
      "dir": "$rootDir/src/assets/favicon.ico",
      "urlPath": "/favicon.ico"
    },
    {
      "alias": "slds",
      "dir": "$rootDir/node_modules/@salesforce-ux/design-system/assets",
      "urlPath": "/public/slds"
    },
    {
      "alias": "localAssets",
      "dir": "$rootDir/src/assets",
      "urlPath": "/public/assets"
    }
  ]
}
